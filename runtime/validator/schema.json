{
  "version": 1,
  "description": "Design document validation schema. Single source of truth for bash, PowerShell, and Python runners.",
  "required_sections": [
    "목표 (Objective)",
    "범위 (Scope)",
    "제약 (Constraints)",
    "구현 단계 (Implementation Steps)",
    "파일/모듈 영향 (Affected Files/Modules)",
    "테스트 기준 (Test Criteria)",
    "오픈 이슈 (Open Issues)"
  ],
  "placeholders": [
    "(이 작업이 달성하려는 것을 1-2문장으로 기술)",
    "(이 작업에 포함되는 것과 포함되지 않는 것을 명시)",
    "(기술적, 시간적, 또는 기타 제약 조건)",
    "(설계 시점에 해결되지 않은 질문이나 리스크)",
    "(이 설계가 의존하는 입력 나열)",
    "(이 설계가 생성할 산출물 나열)",
    "(구현 완료 후 다음 단계 기술)",
    "(프로필 화이트리스트 내 모델 선택)",
    "(프로필 화이트리스트 내 effort 선택)",
    "(선택 근거 1줄)"
  ],
  "required_meta_fields": ["Status", "Inputs", "Outputs", "Next step"],
  "allowed_statuses_for_implementation": ["ready", "done"],
  "blocked_statuses": {
    "draft": "설계가 아직 미완성입니다. Status를 'ready'로 변경하세요.",
    "blocked": "설계가 차단 상태입니다.",
    "in-progress": "in-progress 는 구현 상태입니다. design.md 에는 사용하지 않으며, 구현 진행은 implementation-notes.md 에 기록하세요."
  },
  "empty_content_checks": [
    {
      "id": "default_affected_table",
      "regex": "^\\|\\s*\\|\\s*create\\s*/\\s*modify\\s*/\\s*delete\\s*\\|",
      "message": "파일/모듈 영향 테이블이 템플릿 기본값 그대로입니다."
    },
    {
      "id": "empty_checkbox",
      "regex": "^\\s*-\\s+\\[\\s\\]\\s*$",
      "message": "테스트 기준에 내용 없는 빈 체크박스가 있습니다."
    }
  ],
  "non_empty_sections": [
    {
      "id": "affected_files_table",
      "section": "파일/모듈 영향 (Affected Files/Modules)",
      "message": "파일/모듈 영향 섹션에 실제 내용 행이 없습니다. (헤더/구분선만 존재)"
    }
  ],
  "done_gate": {
    "notes_allowed_statuses": ["done"],
    "summary_allowed_statuses": ["done"],
    "manifest_required_fields": ["inputs", "concepts_needed", "related_files"],
    "manifest_placeholders": [
      "(이 task 가 의존하는 입력 문서/데이터)",
      "(kb/concepts/ 중 실제 필요한 문서만; 없으면 `없음`)",
      "(구현·수정 대상 또는 참조할 소스 파일 경로)",
      "(로드 시 주의점; 생략 가능)"
    ]
  },
  "execution_plan": {
    "section": "실행 계획 (Execution Plan)",
    "required_fields": ["implement_model", "implement_effort", "routing_reason"],
    "parallel_table_columns": ["unit", "파일 범위", "depends_on", "group"],
    "legacy_missing_allowed": ["task-001", "task-002", "task-003"],
    "profile_path": "runtime/config/model-profiles.json"
  },
  "review": {
    "contract_path": "collab.md",
    "enum_marker_prefix": "<!-- review-status-enum:",
    "review_dir": "reviews",
    "filename_regex": "^[0-9]{3}\\.md$",
    "required_fields": ["Reviewer", "Target", "Review status", "Generated by", "Feedback", "Action required"],
    "status_field": "Review status",
    "approved_status": "approved",
    "field_placeholders": [
      "(구현 결과에 대한 리뷰 내용)",
      "(구현자가 수행해야 할 항목; 없으면 `없음`)"
    ]
  }
}
